# ─── Database (required on Vercel, optional when self-hosting) ────────────────
# Type: mongodb | postgresql | mysql | sqlite | redis
DATABASE_TYPE=mongodb

# Full connection string for the chosen database
# MongoDB Atlas example:
DATABASE_URL=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/shor
# Neon / Supabase / Railway PostgreSQL example:
# DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# ─── Remote shor-server (optional) ───────────────────────────────────────────
# URL of a self-hosted shor-server instance (from Settings → Download Server)
# REMOTE_SERVER_URL=http://localhost:4000
